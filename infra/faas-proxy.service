[Unit]
Description=FaaS Engine Proxy Gateway
After=network.target
Requires=network.target

[Service]
Type=simple
User=ec2-user
WorkingDirectory=/opt/faas-engine

ExecStart=/opt/faas-engine/proxy

Restart=always
RestartSec=5

Environment=PROXY_PORT=80
Environment=RUNTIME_URL=http://localhost
Environment=RUNTIME_PORT=8080

StandardOutput=journal
StandardError=journal

StartLimitIntervalSec=60
StartLimitBurst=10

[Install]
WantedBy=multi-user.target