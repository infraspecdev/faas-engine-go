[Unit]
Description=FaaS Engine Runtime Manager
After=network.target docker.service
Requires=docker.service

[Service]
Type=simple
User=ec2-user
ExecStart=/opt/faas-engine/runtime-manager
Restart=always
RestartSec=5

Environment=PORT=8080
Environment=DB_URL=/opt/faas-engine/faas.db

[Install]
WantedBy=multi-user.target
